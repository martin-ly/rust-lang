# =============================================================================
# Rust / Cargo
# =============================================================================

# Cargo build output (shared target directory and nested crate targets)
/target/
**/target/

# Root Cargo.lock is tracked for this workspace (contains binaries and examples)
# Sub-directory Cargo.lock files should be ignored
# More information: https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
/**/Cargo.lock
!/Cargo.lock

# Backup files generated by rustfmt
**/*.rs.bk

# =============================================================================
# Windows MSVC
# =============================================================================

# Executables and debug symbols
*.exe
*.pdb
*.ilk

# Static / dynamic libraries
*.lib
*.dll

# Object files
*.obj
*.o

# Rust static libraries (intermediate)
*.rlib

# =============================================================================
# IDE / Editor
# =============================================================================

# VS Code (keep settings for team consistency, ignore local overrides)
.vscode/*.local

# RustRover / IntelliJ
.idea/
*.iml

# Vim / Emacs
*.swp
*.swo
*~
.#*

# =============================================================================
# OS
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
.directory

# =============================================================================
# Project-specific
# =============================================================================

# mdBook build output (generated HTML site, keep source markdown in src/ if any)
/book/

# Local cargo artifacts override
/cargo-artifacts

# Python cache
__pycache__/
*.pyc
*.pyo
*.py[cod]
*$py.class

# Temporary directories and files
/temp/
/tmp/
*.tmp
*.temp
*.bak
*.orig
*.swp

# Log files
*.log
/logs/

# Local agent plans and cache
.kimi/plans/
.kimi/cache/

# Environment and secrets
.env
.env.local

# Coverage and test artifacts
coverage/
*.profraw
*.profdata

# Documentation build artifacts
docs/_build/
