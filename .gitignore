# =============================================================================
# Rust / Cargo
# =============================================================================

# Cargo build output (shared target directory)
target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information: https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock

# Backup files generated by rustfmt
**/*.rs.bk

# =============================================================================
# Windows MSVC
# =============================================================================

# Executables and debug symbols
*.exe
*.pdb
*.ilk

# Static / dynamic libraries
*.lib
*.dll

# Object files
*.obj
*.o

# Rust static libraries (intermediate)
*.rlib

# =============================================================================
# IDE / Editor
# =============================================================================

# VS Code (keep settings for team consistency, ignore local overrides)
.vscode/*.local

# RustRover / IntelliJ
.idea/
*.iml

# Vim / Emacs
*.swp
*.swo
*~
.#*

# =============================================================================
# OS
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
.directory

# =============================================================================
# Project-specific
# =============================================================================

# mdBook build output
book/book/

# Local cargo artifacts override
/cargo-artifacts
